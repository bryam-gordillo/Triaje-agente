# =============================================================================
# SOC Alert Triage Agent - Environment template
# -----------------------------------------------------------------------------
# Copy this file to ".env" and fill in your own values.
# The system runs fully offline with AGENT_BACKEND=local (no Azure needed).
# =============================================================================

# Backend selector: "local" (default, no cloud) or "foundry" (Azure AI Foundry).
AGENT_BACKEND=local

# --- Azure AI Foundry (only required when AGENT_BACKEND=foundry) -------------
AZURE_AI_PROJECT_ENDPOINT=https://your-foundry-project.services.ai.azure.com/api/projects/your-project
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o

# --- Foundry IQ (knowledge base for cited runbook retrieval) ----------------
FOUNDRY_IQ_KNOWLEDGE_NAME=soc-runbooks

# --- Fabric IQ (business-asset criticality) ---------------------------------
FABRIC_IQ_DATASET=

# --- Work IQ (human-in-the-loop notification to the on-call analyst) --------
WORK_IQ_NOTIFY_TARGET=

# --- Runtime knobs -----------------------------------------------------------
LOG_LEVEL=INFO
